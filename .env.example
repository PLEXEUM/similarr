# ============================================================================
# Similarr - Configuration File
# ============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to git - it contains secrets!
# ============================================================================

# ===== Plex Configuration =====
# Your Plex server URL (e.g., http://192.168.0.77:32400)
PLEX_URL=http://192.168.0.77:32400

# Your Plex authentication token
# Find it: Plex Web UI → Settings → Devices → Your Server → Show Token
PLEX_TOKEN=your_plex_token_here

# ===== Radarr Configuration =====
# Your Radarr server URL (e.g., http://192.168.0.77:7878)
RADARR_URL=http://192.168.0.77:7878

# Your Radarr API key
# Find it: Radarr → Settings → General → API Key
RADARR_API_KEY=your_radarr_api_key_here

# Where Radarr stores movies (e.g., /media/movies)
RADARR_ROOT_FOLDER_PATH=/media/movies

# Optional: Specific quality profile ID (leave empty to use first available)
# Find it: Radarr → Settings → Quality Profiles → ID in URL or API response
RADARR_QUALITY_PROFILE_ID=

# ===== TMDB Configuration =====
# Get a free API key from: https://www.themoviedb.org/signup
# Then request an API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ===== Similarity Settings =====
# Options: tmdb_only, hybrid
# tmdb_only = Only use TMDB's "similar movies" endpoint
# hybrid = TMDB similar + LLM suggestions (requires OpenAI config below)
SIMILARITY_MODE=hybrid

# How many TMDB similar movies to fetch per source movie
TMDB_SIMILAR_LIMIT=20

# ===== LLM Settings (required if SIMILARITY_MODE=hybrid) =====
# For OpenAI: provide OPENAI_API_KEY only
# For Ollama/Local: provide OPENAI_BASE_URL and use dummy key
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini

# How many LLM suggestions to request per source movie
LLM_MAX_RECOMMENDATIONS=5

# ===== Volume Control =====
# Maximum similar movies to add per source movie (1-10 recommended)
MAX_SIMILAR_PER_SOURCE=3

# Maximum total movies to add per run (safety limit)
MAX_ADDITIONS_PER_RUN=10

# How many days back to check Plex watch history
RECENT_DAYS=7

# Skip reprocessing same source movie within this many hours
SKIP_HOURS=24

# ===== Quality Filters =====
# Minimum TMDB rating (0-10) - movies below this are skipped
MIN_TMDB_RATING=6.0

# Minimum vote count - movies with fewer votes are skipped
MIN_VOTE_COUNT=100

# Skip movies already watched on Plex (even if not in Radarr)
SKIP_IF_ALREADY_WATCHED=true

# Skip movies not yet released
HIDE_FUTURE_RELEASES=true

# ===== Radarr Add Behavior =====
# Set to true to automatically trigger search after adding
# false = add to Radarr but wait for scheduled RSS sync
AUTO_SEARCH_AFTER_ADD=false

# ===== Dry Run Mode =====
# Set to true to simulate without actually adding to Radarr
# false = actually add movies to Radarr
DRY_RUN=false

# ===== Logging =====
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO